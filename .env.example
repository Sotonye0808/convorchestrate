# Convorchestrate — environment variables
# Copy to .env and fill in real values. Never commit .env.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://convorchestrate:convorchestrate@localhost:5432/convorchestrate?sslmode=disable

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# ── Meta / WhatsApp Cloud API ─────────────────────────────────────────────────
# dashboard.developers.facebook.com → your app → WhatsApp → API Setup
META_PHONE_NUMBER_ID=
META_ACCESS_TOKEN=
META_WABA_ID=
META_APP_ID=
META_APP_SECRET=
OLD_META_APP_SECRET=                # for zero-downtime secret rotation

# Webhook verify token — set this same value in Meta's webhook config
META_WEBHOOK_VERIFY_TOKEN=

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000   # or https://your-frontend.up.railway.app
CORS_ORIGIN=http://localhost:3000

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development

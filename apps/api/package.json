{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "test": "npm run build && node --test \"dist/**/*.test.js\"",
    "migration:run": "typeorm-ts-node-commonjs -d src/db/data-source.ts migration:run",
    "migration:generate": "typeorm-ts-node-commonjs -d src/db/data-source.ts migration:generate src/db/migrations/init"
  },
  "dependencies": {
    "@convorchestrate/core": "0.1.0",
    "@convorchestrate/meta-api": "0.1.0",
    "@convorchestrate/schemas": "0.1.0",
    "@convorchestrate/utils": "0.1.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/multipart": "^8.3.1",
    "@fastify/rate-limit": "^9.1.0",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-fastify": "^10.3.0",
    "@nestjs/typeorm": "^10.0.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.79.1",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.2.0",
    "nestjs-pino": "^4.6.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.11.5",
    "pino": "^9.14.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/passport-jwt": "^4.0.1",
    "pino-pretty": "^13.1.3"
  }
}
